{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/transcript.js": { "maxDuration": 60 },
    "api/auth.js": { "maxDuration": 60 },
    "api/payment-monitor.js": { "maxDuration": 60 },
    "api/monitor.js": { "maxDuration": 60 },
    "api/blue-editor.js": { "maxDuration": 60 },
    "api/generate-from-zero.js": { "maxDuration": 60 },
    "api/rewrite.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/payment-monitor",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/learning-cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/blue-maintenance",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/reactivation-emails",
      "schedule": "0 10 * * 3"
    },
    {
      "path": "/api/email-marketing",
      "schedule": "0 10 * * 2,5"
    },
    {
      "path": "/api/milestone-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/weekly-trends-email",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/blueclean-poll",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/blue-stories?action=limpar",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/blue-feed?action=update-trending",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/blue-feed?action=limpar-rate-limits",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/blue-lives?action=limpar-lives-antigas",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/blue-legendas?action=processar-fila",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/blue-backup?action=executar",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/blue-monetizacao?action=distribuir-fundo",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/monitor-health",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/pioneiros?action=processar-qualificacoes",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/webhook?action=reprocessar",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    },
    {
      "source": "/blueEditor",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/blue-sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/(.*).jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/toolbar.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*).mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*).webm",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
