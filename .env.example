# ═══════════════════════════════════════════════════════════════
# BlueTube — Variáveis de ambiente
# Copie para .env.local e preencha os valores
# ═══════════════════════════════════════════════════════════════

# ── SUPABASE (obrigatório) ─────────────────────────────────────
# https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── STRIPE (obrigatório para pagamentos) ───────────────────────
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── ADMIN ──────────────────────────────────────────────────────
# Chave de acesso ao painel admin (você define)
ADMIN_SECRET=sua-chave-admin-secreta

# ── SITE ───────────────────────────────────────────────────────
SITE_URL=https://bluetubeviral.com

# ── IA — ROTEIROS E MODERAÇÃO ─────────────────────────────────
# https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# https://aistudio.google.com → API Keys
GEMINI_API_KEY=AI...

# ── ELEVENLABS — VOZES ─────────────────────────────────────────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=...

# ── EMAIL — RESEND ─────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...

# ── 100MS — LIVES (opcional) ──────────────────────────────────
# https://dashboard.100ms.live → Developer → App Details
HMS_APP_ID=
HMS_APP_SECRET=
HMS_TEMPLATE_ID=

# ── UPSTASH REDIS — CACHE (opcional) ──────────────────────────
# https://upstash.com → Create Database → REST API
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── CLOUDFLARE STREAM — HLS (opcional) ────────────────────────
# https://dash.cloudflare.com → Stream → API Tokens
CF_STREAM_TOKEN=
CF_ACCOUNT_ID=

# ── SUPABASE CDN (opcional) ───────────────────────────────────
# Se usar CDN externo para assets do Supabase Storage
SUPABASE_CDN_URL=

# ── COBALT — DOWNLOADS (interno) ──────────────────────────────
# Instância self-hosted do Cobalt
COBALT_URL=https://cobalt-production-xxxx.up.railway.app
COBALT_API_KEY=

# ── RAILWAY — FFMPEG (interno) ────────────────────────────────
RAILWAY_FFMPEG_URL=https://bluetube-ffmpeg-production.up.railway.app

# ── ASAAS — SAQUES DE AFILIADOS VIA PIX (opcional) ────────────
# https://www.asaas.com → Configurações → Integrações → API Key
# Enquanto nao configurado, saques entram em fila manual e o
# admin processa no painel (modo fail-graceful).
ASAAS_API_KEY=
# sandbox | production — default sandbox (use production quando ASAAS_API_KEY for de producao)
ASAAS_ENVIRONMENT=sandbox

# ── TAXAS DE GATEWAY (usadas no calculo de receita liquida) ───
# Defaults: Stripe 3.99% + R$0,39 | ASAAS R$1,99 por saque mensal
STRIPE_FEE_PCT=0.0399
STRIPE_FEE_FIXED=0.39
ASAAS_FEE_FIXED=1.99
